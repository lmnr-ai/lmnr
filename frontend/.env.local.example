BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=next_secret_abc
BACKEND_URL=http://localhost:8000
BACKEND_RT_URL=http://localhost:8002
NEXT_OTEL_FETCH_DISABLED=1
SHARED_SECRET_TOKEN=some_secret

# these must match what you have in your docker-compose-local-dev.yml for postgres
# postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@{host}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_URL="postgres://postgres:postgres_passwordabc@localhost:5433/postgres"
DATABASE_MAX_CONNECTIONS=10
FORCE_RUN_MIGRATIONS=false
FORCE_EMAIL_AUTH=false

# Optional. Postgres schema all tables live in (applied as the connection
# search_path). Defaults to "public". Must match the app-server's POSTGRES_SCHEMA.
# When set to a non-public schema, migrations are also tracked inside it
# (drizzle.__drizzle_migrations moves into the schema) so a Laminar database can
# coexist with another Drizzle-managed service in the same instance.
# POSTGRES_SCHEMA=public
# Set to false if the schema is pre-provisioned or the DB role lacks CREATE.
# POSTGRES_CREATE_SCHEMA=true

# must be 32 bytes (64 hex characters) long
AEAD_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# replace with FULL if you are testing with a full stack
# ENVIRONMENT=FULL
ENVIRONMENT=LITE
CLICKHOUSE_USER=ch_user
CLICKHOUSE_PASSWORD=ch_passwd
CLICKHOUSE_URL=http://localhost:8123
# for auth
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_OKTA_CLIENT_ID=
AUTH_OKTA_CLIENT_SECRET=
AUTH_OKTA_ISSUER=
AUTH_KEYCLOAK_ID=
AUTH_KEYCLOAK_SECRET=
AUTH_KEYCLOAK_ISSUER=

# for s3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_TRACE_PAYLOADS_BUCKET=

REDIS_URL=
OPENAI_API_KEY=

# AI features (chat-with-trace, SQL generation, span previews, signals, etc.)
# Pick one provider: openai | gemini | bedrock. LLM_MODEL_* overrides are
# optional — per-provider defaults apply when unset.
#
# openai also works with OpenAI-compatible gateways (LiteLLM, OpenRouter,
# vLLM, etc.) via LLM_BASE_URL.
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://localhost:4000
# LLM_API_KEY=
# LLM_MODEL_SMALL=
# LLM_MODEL_MEDIUM=
# LLM_MODEL_LARGE=
#
# bedrock reads AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION
# (no LLM_API_KEY).
# LLM_PROVIDER=bedrock

QUERY_ENGINE_URL=
QUICKWIT_SEARCH_URL=
