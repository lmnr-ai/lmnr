NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=next_secret_abc
BACKEND_URL=http://localhost:8000
BACKEND_RT_URL=http://localhost:8002
NEXT_OTEL_FETCH_DISABLED=1
SHARED_SECRET_TOKEN=some_secret

# these must match what you have in your docker-compose-local-dev.yml for postgres
# postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@{host}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_URL="postgres://postgres:postgres_passwordabc@localhost:5433/postgres"
DATABASE_MAX_CONNECTIONS=10
FORCE_RUN_MIGRATIONS=false
FORCE_EMAIL_AUTH=false

# must be 32 bytes (64 hex characters) long
AEAD_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# replace with FULL if you are testing with a full stack
# ENVIRONMENT=FULL
ENVIRONMENT=LITE
CLICKHOUSE_USER=ch_user
CLICKHOUSE_PASSWORD=ch_passwd
CLICKHOUSE_URL=http://localhost:8123
# for auth
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_OKTA_CLIENT_ID=
AUTH_OKTA_CLIENT_SECRET=
AUTH_OKTA_ISSUER=
AUTH_KEYCLOAK_ID=
AUTH_KEYCLOAK_SECRET=
AUTH_KEYCLOAK_ISSUER=

# for s3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_TRACE_PAYLOADS_BUCKET=

REDIS_URL=
OPENAI_API_KEY=

# AI provider for internal features (signals, SQL generation, chat-with-trace, previews).
# Set ONE of the three providers below.
#
# 1) Gemini:
# GOOGLE_GENERATIVE_AI_API_KEY=
#
# 2) Anthropic on AWS Bedrock (reuses AWS_REGION / AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY above):
# BEDROCK_ENABLED=true
#
# 3) OpenAI-compatible gateway (OpenRouter, LiteLLM proxy, vLLM, Together, Groq OpenAI endpoint, ...):
# OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_MODEL=openai/gpt-4o-mini              # "default" tier
# OPENAI_COMPATIBLE_MODEL_FAST=openai/gpt-4o-mini         # optional, falls back to *_MODEL
# OPENAI_COMPATIBLE_MODEL_LITE=openai/gpt-4o-mini         # optional, falls back to *_MODEL_FAST

QUERY_ENGINE_URL=
QUICKWIT_SEARCH_URL=
